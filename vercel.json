{
    "cleanUrls": true,
    "framework": "vite",
    "installCommand": "corepack enable && pnpm install --no-frozen-lockfile",
    "headers": [
        {
            "source": "/assets/(.*)",
            "headers": [
                {
                    "key": "Cache-Control",
                    "value": "public, max-age=31536000, immutable"
                }
            ]
        }
    ]
}